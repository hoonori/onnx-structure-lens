{
  "name": "tiny_transformer_block",
  "inputs": ["x"],
  "outputs": ["out"],
  "tensors": {
    "x": {"shape": [1, 128, 64]},
    "ln1_out": {"shape": [1, 128, 64]},
    "q": {"shape": [1, 128, 64]},
    "k": {"shape": [1, 128, 64]},
    "v": {"shape": [1, 128, 64]},
    "kt": {"shape": [1, 64, 128]},
    "scores": {"shape": [1, 128, 128]},
    "prob": {"shape": [1, 128, 128]},
    "ctx": {"shape": [1, 128, 64]},
    "proj": {"shape": [1, 128, 64]},
    "res1": {"shape": [1, 128, 64]},
    "ln2_out": {"shape": [1, 128, 64]},
    "fc1": {"shape": [1, 128, 256]},
    "gelu": {"shape": [1, 128, 256]},
    "fc2": {"shape": [1, 128, 64]},
    "out": {"shape": [1, 128, 64]},
    "wq": {"shape": [64, 64], "is_initializer": true},
    "wk": {"shape": [64, 64], "is_initializer": true},
    "wv": {"shape": [64, 64], "is_initializer": true},
    "wo": {"shape": [64, 64], "is_initializer": true},
    "w1": {"shape": [64, 256], "is_initializer": true},
    "w2": {"shape": [256, 64], "is_initializer": true}
  },
  "nodes": [
    {"name": "ln1", "op_type": "LayerNormalization", "inputs": ["x"], "outputs": ["ln1_out"]},
    {"name": "q_proj", "op_type": "MatMul", "inputs": ["ln1_out", "wq"], "outputs": ["q"]},
    {"name": "k_proj", "op_type": "MatMul", "inputs": ["ln1_out", "wk"], "outputs": ["k"]},
    {"name": "v_proj", "op_type": "MatMul", "inputs": ["ln1_out", "wv"], "outputs": ["v"]},
    {"name": "k_transpose", "op_type": "Transpose", "inputs": ["k"], "outputs": ["kt"], "attrs": {"perm": [0, 2, 1]}},
    {"name": "qk_scores", "op_type": "MatMul", "inputs": ["q", "kt"], "outputs": ["scores"]},
    {"name": "softmax", "op_type": "Softmax", "inputs": ["scores"], "outputs": ["prob"], "attrs": {"axis": -1}},
    {"name": "attn_ctx", "op_type": "MatMul", "inputs": ["prob", "v"], "outputs": ["ctx"]},
    {"name": "out_proj", "op_type": "MatMul", "inputs": ["ctx", "wo"], "outputs": ["proj"]},
    {"name": "residual_1", "op_type": "Add", "inputs": ["x", "proj"], "outputs": ["res1"]},
    {"name": "ln2", "op_type": "LayerNormalization", "inputs": ["res1"], "outputs": ["ln2_out"]},
    {"name": "fc1", "op_type": "MatMul", "inputs": ["ln2_out", "w1"], "outputs": ["fc1"]},
    {"name": "gelu", "op_type": "Gelu", "inputs": ["fc1"], "outputs": ["gelu"]},
    {"name": "fc2", "op_type": "MatMul", "inputs": ["gelu", "w2"], "outputs": ["fc2"]},
    {"name": "residual_2", "op_type": "Add", "inputs": ["res1", "fc2"], "outputs": ["out"]}
  ]
}
